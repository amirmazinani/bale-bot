# Copy this file to .env (or export these in your shell / process manager)
# and fill in real values. Never commit a real .env file with a live token.

# --- Required -----------------------------------------------------------
BALE_BOT_TOKEN=1234567890:yourtoken

# --- API endpoint (defaults already point at Bale; override only to test
# the SAME codebase against real Telegram, or a local Bot API server) ----
# BOT_API_BASE_URL_TEMPLATE=https://tapi.bale.ai/bot{token}/{method}
# BOT_API_FILE_URL_TEMPLATE=https://tapi.bale.ai/file/bot{token}/{path}
#
# To test against Telegram instead, uncomment:
# BOT_API_BASE_URL_TEMPLATE=https://api.telegram.org/bot{token}/{method}
# BOT_API_FILE_URL_TEMPLATE=https://api.telegram.org/file/bot{token}/{path}

# --- Networking mode ------------------------------------------------------
USE_WEBHOOK=false
# WEBHOOK_HOST=https://yourdomain.example.com
# WEBHOOK_PATH=/webhook/bale
# WEBAPP_HOST=0.0.0.0
# WEBAPP_PORT=8080

# --- Optional: forward demo-request leads to an admin chat --------------
# ADMIN_CHAT_ID=1234567890

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
LOG_TO_FILE=true
